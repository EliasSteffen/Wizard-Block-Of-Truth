      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Summe aller Ansagen darf nicht der Handgrösse entsprechen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
