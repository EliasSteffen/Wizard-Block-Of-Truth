    "Domain.Constraint.Game.BetSumNotEqualHandSize.Failure" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Summe der Ansagen darf nicht der Handgrösse entsprechen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bets cannot add up to the hand size."
          }
