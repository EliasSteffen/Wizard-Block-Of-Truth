    "UI.Info.Body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese App digitalisiert den Papier-Wertungsblock („Block of Truth“), mit dem beim Kartenspiel Wizard Wetten und Stiche festgehalten werden. Wizard ist ein veröffentlichtes Kartenspiel; diese App ist ein unabhängiges Hilfsmittel und steht in keiner Verbindung zum Verlag oder den Rechteinhabern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app digitizes the paper score sheet — the “block of truth” — used to record bids and tricks when playing the card game Wizard. Wizard is a published card game; this app is an independent helper and is not affiliated with the publisher or rights holders."
          }
        }
      }
    },
