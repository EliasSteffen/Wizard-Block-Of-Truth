    "Domain.Card.Cloud.Description" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Spieler, der den Stich mit der Wolkenkarte gewinnt, muss seine Ansage um 1 erhöhen oder verringern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The Player who won the trick containing the Cloud-Card must increase or decrease his bet by 1."
          }
        }
      }
    },
