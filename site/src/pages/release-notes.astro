---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ReleaseEntry from '../components/ReleaseEntry.astro';
import { getDictionary, pathHref } from '../lib/i18n';

const t = getDictionary();
const releases = (await getCollection('releases')).sort((a, b) => b.data.sortOrder - a.data.sortOrder);
---

<BaseLayout
  currentPath="/release-notes/"
  title={t.meta.releaseNotesTitle}
  description={t.meta.releaseNotesDescription}
>
  <div class="subpage-main">
    <article class="subpage-card">
      <h1>{t.releaseNotes.title}</h1>
      <p class="release-intro">{t.releaseNotes.intro}</p>

      <ol class="release-list">
        {releases.map((entry) => (
          <ReleaseEntry
            version={entry.data.version}
            date={entry.data.date}
            items={entry.data.items}
          />
        ))}
      </ol>

      <a class="back-link" href={pathHref('/')}>← {t.releaseNotes.back}</a>
    </article>
  </div>
</BaseLayout>
