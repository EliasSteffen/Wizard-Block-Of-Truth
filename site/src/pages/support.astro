---
import BaseLayout from '../layouts/BaseLayout.astro';
import { GITHUB_ISSUES_URL, GITHUB_URL } from '../config';
import { getDictionary, pathHref } from '../lib/i18n';

const t = getDictionary();
---

<BaseLayout
  currentPath="/support/"
  title={t.meta.supportTitle}
  description={t.meta.supportDescription}
>
  <div class="subpage-main">
    <article class="subpage-card">
      <h1>{t.support.title}</h1>
      <p>{t.support.intro}</p>

      <div class="subpage-links">
        <a class="subpage-link-row" href={GITHUB_ISSUES_URL} rel="noopener noreferrer">
          <div>
            <span class="link-label">{t.support.issuesLabel}</span>
            <p class="link-desc">{t.support.issuesText}</p>
          </div>
          <span style="margin-left: auto; color: var(--muted);">↗</span>
        </a>
        <a class="subpage-link-row" href={GITHUB_URL} rel="noopener noreferrer">
          <div>
            <span class="link-label">{t.support.repoLabel}</span>
            <p class="link-desc">{GITHUB_URL.replace('https://', '')}</p>
          </div>
          <span style="margin-left: auto; color: var(--muted);">↗</span>
        </a>
      </div>

      <h2>{t.support.faqTitle}</h2>
      <div class="faq-list">
        {t.support.faq.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>

      <a class="back-link" href={pathHref('/')}>← {t.support.back}</a>
    </article>
  </div>
</BaseLayout>
