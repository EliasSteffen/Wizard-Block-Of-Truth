---
import type { Dictionary } from '../lib/i18n';

interface Props {
  t: Dictionary;
}

const { t } = Astro.props;

const accentColors = ['#4F6EFF', '#F5A623', '#34D399', '#8BA3FF'];
const icons = ['🃏', '⚡', '📊', '🛡'];
---

<section class="section" id="features">
  <div class="site-shell">
    <p class="section-label">Features</p>
    <h2 class="section-heading">{t.features.title}</h2>
    <p class="section-intro">{t.features.intro}</p>

    <div class="feature-grid">
      {t.features.items.map((item, i) => (
        <article class="feature-card">
          <div class="feature-accent" style={`background: ${accentColors[i % accentColors.length]};`}></div>
          <span class="feature-icon">{icons[i % icons.length]}</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
