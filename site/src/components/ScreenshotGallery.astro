---
import PhoneFrame from './PhoneFrame.astro';
import type { Dictionary } from '../lib/i18n';

interface Props {
  t: Dictionary;
}

const { t } = Astro.props;
---

<section class="section" id="screenshots">
  <h2>{t.screenshots.title}</h2>
  <p class="section-intro">{t.screenshots.intro}</p>
  <div class="screenshot-scroll">
    {
      t.screenshots.items.map((shot) => (
        <figure class="shot-card">
          <PhoneFrame src={shot.src} alt={shot.alt} />
          <figcaption class="shot-label">{shot.caption}</figcaption>
        </figure>
      ))
    }
  </div>
</section>
