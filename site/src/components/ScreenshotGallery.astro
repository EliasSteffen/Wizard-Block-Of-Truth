---
import type { Dictionary } from '../lib/i18n';
import { assetUrl } from '../lib/assets';

interface Props {
  t: Dictionary;
}

const { t } = Astro.props;
---

<section class="section" id="screenshots">
  <div class="site-shell">
    <p class="section-label">App Preview</p>
    <h2 class="section-heading">{t.screenshots.title}</h2>
    <p class="section-intro">{t.screenshots.intro}</p>

    <div class="screenshot-grid">
      {t.screenshots.items.map((shot) => (
        <figure class="shot-card">
          <div class="shot-image-wrap">
            <img
              src={assetUrl(shot.src)}
              alt={shot.alt}
              loading="lazy"
              decoding="async"
            />
          </div>
          <figcaption class="shot-meta">
            <span class="shot-label">{shot.caption}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
