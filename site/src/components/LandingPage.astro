---
import AppStoreButton from './AppStoreButton.astro';
import FeatureShowcase from './FeatureShowcase.astro';
import ScreenshotGallery from './ScreenshotGallery.astro';
import { GITHUB_URL } from '../config';
import { pathHref, type Dictionary } from '../lib/i18n';

interface Props {
  t: Dictionary;
}

const { t } = Astro.props;
---

<!-- Hero -->
<section class="site-shell hero">
  <p class="hero-eyebrow">✦ {t.hero.eyebrow}</p>

  <h1 class="hero-title">
    The modern score sheet<br />
    <em>for Wizard nights.</em>
  </h1>

  <p class="hero-lead">{t.hero.lead}</p>

  <div class="hero-cta-row">
    <AppStoreButton label={t.cta.appStore} soonLabel={t.cta.appStoreSoon} class="btn btn-primary" />
    <a class="btn btn-ghost" href={GITHUB_URL} rel="noopener noreferrer">{t.cta.github}</a>
    <a class="btn btn-ghost" href={pathHref('/support/')}>{t.cta.support}</a>
  </div>

  <ul class="hero-stats">
    <li class="stat-pill">
      <span class="val">2–6</span>
      <span class="stat-divider"></span>
      <span class="lbl">{t.hero.metricPlayers}</span>
    </li>
    <li class="stat-pill">
      <span class="val">LAN</span>
      <span class="stat-divider"></span>
      <span class="lbl">{t.hero.metricMultiplayer}</span>
    </li>
    <li class="stat-pill">
      <span class="val">0</span>
      <span class="stat-divider"></span>
      <span class="lbl">{t.hero.metricTrackers}</span>
    </li>
  </ul>
</section>

<FeatureShowcase t={t} />
<ScreenshotGallery t={t} />

<!-- How it works -->
<section class="section" id="how-it-works">
  <div class="site-shell">
    <p class="section-label">How it works</p>
    <h2 class="section-heading">{t.howItWorks.title}</h2>
    <p class="section-intro">{t.howItWorks.intro}</p>

    <div class="steps-grid">
      {t.howItWorks.steps.map((step, i) => (
        <article class="step-card">
          <span class="step-badge">0{i + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Trust -->
<section class="section" id="trust">
  <div class="site-shell">
    <div class="trust-card">
      <div>
        <p class="section-label">{t.trust.title}</p>
        <h2>{t.trust.title}</h2>
      </div>
      <p style="color: var(--muted);">{t.trust.intro}</p>
      <ul class="checklist">
        {t.trust.items.map((item) => <li>{item}</li>)}
      </ul>
      <p class="attribution">{t.trust.attribution}</p>
      <p>
        <a href={pathHref('/privacy/')}>{t.trust.privacyLink}</a>
      </p>
    </div>
  </div>
</section>
