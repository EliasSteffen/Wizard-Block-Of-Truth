---
import { pathHref, type Dictionary } from '../lib/i18n';

interface Props {
  t: Dictionary;
}

const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-shell footer-row">
    <small>&copy; {year} {t.footer.copyright}</small>
    <nav class="footer-links" aria-label="Footer">
      <a href={pathHref('/privacy/')}>{t.nav.privacy}</a>
      <a href={pathHref('/support/')}>{t.nav.support}</a>
      <a href={pathHref('/release-notes/')}>{t.nav.releaseNotes}</a>
    </nav>
  </div>
</footer>
